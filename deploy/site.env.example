# Per-site config, installed on the instance at /etc/parody-book-host/site.env
# (chmod 600 — it holds secrets). One file per book site. Book-agnostic deploy
# reads these; the host repo stays the same across all sites.

# --- where the app runs ---
APP_DIR=/opt/parody-book-host
VENV=/opt/parody-book-host/.venv
SERVICE=parody-book-host          # systemd unit name

# --- which book this site serves ---
BOOK_SLUG=real-time-computing

# --- where its content comes from (book's own content repo release) ---
CONTENT_REPO=ricopicone/real-time-computing-parody
ARTIFACT_ASSET=real-time-computing.json
MEDIA_ASSET=media.zip             # optional; omit if no media
# RELEASE_TAG=v1.0.0              # omit for latest
GH_TOKEN=ghp_xxx_read_only_to_content_repos

# --- Django settings (see booksite/settings.py) ---
BOOKSITE_SECRET_KEY=change-me-long-random
BOOKSITE_DEBUG=0
BOOKSITE_ALLOWED_HOSTS=rtcbook.org,www.rtcbook.org
BOOKSITE_CSRF_TRUSTED_ORIGINS=https://rtcbook.org,https://www.rtcbook.org
BOOKSITE_BOOK_SLUG=real-time-computing
BOOKSITE_MEDIA_ROOT=/var/lib/parody-book-host/media
DATABASE_URL=postgres://user:pass@your-rds-endpoint:5432/rtcbook
